// Hospital Patient Registration System

alert("Welcome to the Hospital Patient Registration System!");

// Variables
var patientName;
var disease;
var wardType;
var age;
var daysAdmitted;
var roomChargePerDay;
var totalBill;
var discount = 0;
var finalBill;
var admittedPatients = 0;
var admissionStatus;

// User Input
patientName = prompt("Enter Patient Name:");
age = Number(prompt("Enter Patient Age:"));
disease = prompt("Enter Disease:");
daysAdmitted = Number(prompt("Enter Number of Days Admitted:"));
wardType = prompt("Enter Ward Type (General / Private / VIP):");

// Confirm Admission
var confirmAdmission = confirm("Do you want to confirm the hospital admission?");

// Set Room Charges
if (wardType == "General") {
    roomChargePerDay = 1000;
}
else if (wardType == "Private") {
    roomChargePerDay = 2000;
}
else if (wardType == "VIP") {
    roomChargePerDay = 3500;
}
else {
    roomChargePerDay = 0;
    console.log("Invalid Ward Type");
}

// Function: Welcome Patient
function welcomePatient() {
    console.log("Welcome " + patientName + "! Your hospital registration has been completed successfully.");
}

// Function: Check Eligibility
function checkEligibility() {
    if (age >= 12) {
        console.log("Patient is eligible for admission.");
        return true;
    } else {
        console.log("Patient is not eligible for admission.");
        return false;
    }
}

// Function: Calculate Discount
function calculateDiscount() {
    if (daysAdmitted > 10) {
        discount = totalBill * 20 / 100;
    }
    else if (daysAdmitted >= 5 && daysAdmitted <= 10) {
        discount = totalBill * 10 / 100;
    }
    else {
        discount = 0;
    }
}

// Function: Calculate Final Bill
function calculateFinalBill() {
    finalBill = totalBill - discount;
}

// Total Bill
totalBill = roomChargePerDay * daysAdmitted;

// Even or Odd Age
if (age % 2 == 0) {
    console.log("Patient Age is Even.");
} else {
    console.log("Patient Age is Odd.");
}

// Increase Admitted Patients
admittedPatients++;

// Greeting
welcomePatient();

// Eligibility
checkEligibility();

// Admission Confirmation
if (confirmAdmission && age >= 12) {
    admissionStatus = "Confirmed";
    console.log("Admission Confirmed.");
}
else {
    admissionStatus = "Rejected";
    console.log("Admission Rejected.");
}

// Nested If
if (age >= 12) {
    if (wardType == "General" || wardType == "Private" || wardType == "VIP") {
        calculateDiscount();
    }
}

// Final Bill
calculateFinalBill();

console.log("Total Bill: " + totalBill);
console.log("Discount: " + discount);
console.log("Final Bill: " + finalBill);

// Display Days
for (var i = 1; i <= daysAdmitted; i++) {
    console.log("Day " + i);
}

// Registration Complete
var registrationComplete = false;

for (var j = 1; j <= 5; j++) {
    if (!registrationComplete) {
        console.log("Processing Admission...");
        registrationComplete = true;
        console.log("Admission Completed Successfully.");
        break;
    }
}

// Receipt

console.log("     HOSPITAL REGISTRATION RECEIPT      ");

console.log("Patient Name : " + patientName);
console.log("Age : " + age);
console.log("Disease : " + disease);
console.log("Ward Type : " + wardType);
console.log("Days Admitted : " + daysAdmitted);
console.log("Room Charge/Day : Rs. " + roomChargePerDay);
console.log("Total Bill : Rs. " + totalBill);
console.log("Discount : Rs. " + discount);
console.log("Final Bill : Rs. " + finalBill);
console.log("Admission Status : " + admissionStatus);
console.log("Admitted Patients : " + admittedPatients);

console.log("Thank You! Get Well Soon.");
